@PACKAGE_INIT@

set(_CommonUtils_supported_components StringUtils)

foreach(_comp ${CommonUtils_FIND_COMPONENTS})
  if (NOT _comp IN_LIST _CommonUtils_supported_components)
    set(CommonUtils_FOUND False)
    set(CommonUtils_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
  endif()
  include("${CMAKE_CURRENT_LIST_DIR}/CommonUtils${_comp}Targets.cmake")
endforeach()
